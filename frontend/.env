# Production Environment Variables for Vercel Deployment
# Copy this file to .env.production and fill in your values

# Backend API URL (Your VPS backend URL)
# IMPORTANT: This must match your VPS IP address where the backend is running

# For production with VPS IP (current setup):
# VITE_API_URL=http://82.25.108.30:5000
VITE_API_URL=http://localhost:5000

# For production with domain (recommended for SSL/HTTPS):
# VITE_API_URL=https://api.yourdomain.com

# For local development, use:
# VITE_API_URL=http://localhost:5000

# Optional: Analytics, monitoring, etc.
# VITE_GA_TRACKING_ID=UA-XXXXXXXXX-X
