# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# Server
PORT=5000
NODE_ENV=development

# Redis
REDIS_URL="redis://localhost:6379"

# SMS Gateway (MSG91/Twilio)
SMS_PROVIDER="msg91"
SMS_API_KEY="your-sms-api-key"
SMS_SENDER_ID="HMSAPP"
OTP_TEMPLATE_ID="your-template-id"

# WhatsApp Business API
WHATSAPP_API_URL="https://graph.facebook.com/v17.0"
WHATSAPP_TOKEN="your-whatsapp-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID="rzp_test_xxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="HMS Hospital <noreply@hms.com>"

# File Storage (AWS S3)
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="hms-uploads"

# ABDM Integration
ABDM_GATEWAY_URL="https://dev.abdm.gov.in"
ABDM_CLIENT_ID="your-client-id"
ABDM_CLIENT_SECRET="your-client-secret"

# Frontend URL (comma-separated for multiple origins)
# IMPORTANT: Include both localhost for development and your Vercel URL for production
FRONTEND_URL="http://localhost:3000,https://hms-ten-indol.vercel.app"
